{
    "crons": [
        {
            "path": "/api/cron-reminders",
            "schedule": "0 10-23 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/emusys-api/:path*",
            "destination": "https://api.emusys.com.br/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}